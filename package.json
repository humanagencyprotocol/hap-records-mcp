{
  "name": "@humanagencyp/records-mcp",
  "version": "1.0.0",
  "description": "Records MCP server for the Human Agency Protocol — personal knowledge store for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "bin": { "records-mcp": "dist/index.js" },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
